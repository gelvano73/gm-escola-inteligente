# Use PostgreSQL, MySQL ou SQLite
# PostgreSQL: postgresql://usuario:senha@localhost:5432/escola_inteligente
# MySQL:      mysql+pymysql://usuario:senha@localhost:3306/escola_inteligente
# SQLite:     sqlite:///./escola.db
DATABASE_URL=sqlite:///./escola.db

SECRET_KEY=altere-esta-chave-secreta-em-producao-gm-escola
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000,null

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=gm-escola-verify-token
WHATSAPP_API_VERSION=v21.0

# OpenAI (GPT + Whisper para áudio)
OPENAI_ENABLED=false
OPENAI_API_KEY=
